{
  "$id": "https://permea-core.local/schemas/benchmark_card.schema.json",
  "additionalProperties": true,
  "properties": {
    "benchmark_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "measured_property": {
      "type": "string"
    },
    "intended_use": {
      "type": "string"
    },
    "status": {
      "enum": [
        "Proposed",
        "Draft",
        "Reproducible Computational Workflow",
        "Active Reference Benchmark",
        "Independently Reproduced",
        "Externally Validated",
        "Deprecated",
        "Archived"
      ],
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "dataset_requirements": {
      "type": "object"
    },
    "evaluation_protocol": {
      "type": "object"
    },
    "metrics": {
      "type": "object"
    },
    "reproducibility_requirements": {
      "type": "object"
    },
    "evidence_links": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "claim_boundaries": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "claim_boundary": {
      "type": "string"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "maintainer_notes": {
      "type": "string"
    },
    "task_type": {
      "type": "string"
    },
    "dataset_card_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "split_policy": {
      "type": "object"
    },
    "metric_set": {
      "type": "object"
    },
    "output_artifacts": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "benchmark_id",
    "name",
    "purpose",
    "measured_property",
    "status",
    "evidence_links",
    "claim_boundaries",
    "claim_boundary",
    "limitations",
    "version"
  ],
  "title": "Permea Benchmark Card",
  "type": "object"
}
